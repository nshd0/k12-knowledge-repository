{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "datasource", "id": "jaeger", "name": "Jaeger", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "description": "IOE EdTech Platform - Observability Dashboard. Monitors token usage, retrieval latency, student accuracy, ingestion throughput, and governance checks across all pipeline planes.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "title": "Agent Plane",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "short"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "id": 1,
      "options": {"legend": {"calcs": ["sum"], "displayMode": "list"}, "tooltip": {"mode": "single"}},
      "targets": [
        {
          "expr": "sum(rate(ioe_edtech_token_usage_total[5m])) by (agent_role, model)",
          "legendFormat": "{{agent_role}} / {{model}}",
          "refId": "A"
        }
      ],
      "title": "Token Usage Rate (tokens/s) by Agent Role",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "unit": "ms",
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 500},
            {"color": "red", "value": 2000}
          ]}
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1},
      "id": 2,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ioe_edtech_retrieval_latency_ms_bucket[5m])) by (le, query_type))",
          "legendFormat": "p95 {{query_type}}",
          "refId": "A"
        }
      ],
      "title": "Retrieval Latency p95 (ms)",
      "type": "gauge"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "id": 101,
      "title": "Student Learning KPIs",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "continuous-GrYlRd"}, "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "yellow", "value": 0.6},
            {"color": "green", "value": 0.8}
          ]}
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "id": 3,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto"},
      "targets": [
        {
          "expr": "ioe_edtech_student_response_accuracy",
          "legendFormat": "{{subject}} Grade {{grade}}",
          "refId": "A"
        }
      ],
      "title": "Student Response Accuracy by Subject",
      "type": "gauge"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "id": 102,
      "title": "Ingestion Pipeline",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "short"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 19},
      "id": 4,
      "targets": [
        {
          "expr": "sum(rate(ioe_edtech_ingestion_docs_total[5m])) by (source, status)",
          "legendFormat": "{{source}} / {{status}}",
          "refId": "A"
        }
      ],
      "title": "Ingestion Throughput (docs/s)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "short"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 19},
      "id": 5,
      "targets": [
        {
          "expr": "sum(rate(ioe_edtech_governance_checks_total[5m])) by (result)",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "title": "Governance Check Rate (checks/s)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 27},
      "id": 103,
      "title": "Distributed Traces (Jaeger)",
      "type": "row"
    },
    {
      "datasource": {"type": "jaeger", "uid": "jaeger"},
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 28},
      "id": 6,
      "options": {
        "query": {"serviceFilter": "ioe-edtech"},
        "traceFormat": "jaeger"
      },
      "targets": [
        {
          "queryType": "search",
          "service": "ioe-edtech",
          "refId": "A"
        }
      ],
      "title": "Recent Traces - IOE EdTech Services",
      "type": "traces"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["ioe", "edtech", "k12", "opentelemetry", "langgraph", "prefect"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "definition": "label_values(ioe_edtech_token_usage_total, agent_role)",
        "hide": 0,
        "includeAll": true,
        "name": "agent_role",
        "options": [],
        "query": "label_values(ioe_edtech_token_usage_total, agent_role)",
        "refresh": 2,
        "type": "query",
        "label": "Agent Role"
      },
      {
        "current": {},
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "definition": "label_values(ioe_edtech_student_response_accuracy, grade)",
        "hide": 0,
        "includeAll": true,
        "name": "grade",
        "options": [],
        "query": "label_values(ioe_edtech_student_response_accuracy, grade)",
        "refresh": 2,
        "type": "query",
        "label": "Grade"
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "IOE EdTech Platform - Observability",
  "uid": "ioe-edtech-obs",
  "version": 1
}
