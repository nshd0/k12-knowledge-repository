# ── Netlify / frontend ───────────────────────────────────────────────────────
VITE_API_BASE=/.netlify/functions
ADMIN_EMAIL=

# ── Hugging Face ─────────────────────────────────────────────────────────────
# Required for Hugging Face Inference API (serverless generation)
# Get your token at https://huggingface.co/settings/tokens
HF_TOKEN=

# Embedding model served via HF Inference API or loaded locally
# Recommended: BAAI/bge-m3 (multilingual) or sentence-transformers/all-MiniLM-L6-v2 (fast)
EMBEDDING_MODEL=BAAI/bge-m3

# Embedding backend: sentence_transformers (local) | hf_api (Inference API) | stub (tests)
EMBEDDING_BACKEND=sentence_transformers

# Cross-encoder reranker model (local via sentence-transformers)
# Leave blank to disable reranking
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Generation model via HF Inference API
# Used by composer.py when LLM_BACKEND=hf_api
HF_GENERATION_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# LLM backend for composer.py: hf_api | ollama | openai | none
LLM_BACKEND=hf_api

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_PATH=./chroma_db
# CHROMA_HOST=           # set to enable HTTP client mode
# CHROMA_PORT=8000

# ── Legacy (OpenAI — only needed if LLM_BACKEND=openai) ──────────────────────
# OPENAI_API_KEY=
